// =============================================================================
// DATABASE SCHEMA: CRACK PROPERTY MANAGEMENT SYSTEM
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// 2. CUSTOM ENUM TYPES
// ---------------------------------------------------------

enum RoleType {
  admin
  tenant

  @@map("role_type_enum")
}

enum MaritalStatus {
  single
  married

  @@map("marital_status_enum")
}

enum RoomType {
  standard
  studio

  @@map("room_type_enum")
}

enum RoomStatus {
  available
  unavailable
  occupied

  @@map("room_status_enum")
}

enum BookingStatus {
  pending_payment
  confirmed
  cancelled
  completed

  @@map("booking_status_enum")
}

enum RentType {
  daily
  weekly
  monthly
  yearly

  @@map("rent_type_enum")
}

enum ComplaintCategory {
  plumbing
  electrical
  furniture
  internet
  other

  @@map("complaint_category_enum")
}

enum ComplaintStatus {
  open
  in_progress
  resolved
  closed

  @@map("complaint_status_enum")
}

enum InvoiceStatus {
  unpaid
  partially_paid
  paid
  expired

  @@map("invoice_status_enum")
}

enum TransactionStatus {
  pending
  verified
  rejected

  @@map("transaction_status_enum")
}

enum NotificationType {
  info
  payment
  maintenance
  promotion

  @@map("notification_type_enum")
}

// ---------------------------------------------------------
// 3. MASTER TABLES (Data Induk)
// ---------------------------------------------------------

model Facility {
  id String @id @default(uuid()) @map("facility_id")
  name        String   @unique @db.VarChar(100)
  description String?
  iconUrl     String?  @map("icon_url") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  roomFacilities RoomFacility[]

  @@map("facilities")
}

model User {
  id String @id @default(uuid()) @map("user_id")
  email      String   @unique @db.VarChar(100)
  password   String?  @db.VarChar(255)
  googleId   String?  @unique @map("google_id") @db.VarChar(255)
  role       RoleType @default(tenant)
  isVerified Boolean  @default(false) @map("is_verified")
  hashedRt   String?  @map("hashed_rt") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  // Relasi 1-to-1 ke Profile
  profile Profile?

  // Relasi Lainnya...
  bookings             Booking[]      @relation("TenantBookings")
  verifiedTransactions Transaction[]  @relation("VerifiedTransactions")
  maintenances         Maintenance[]  @relation("TenantMaintenances")
  conversations        Conversation[] @relation("TenantConversations")
  messages             Message[]      @relation("SentMessages")
  notifications        Notification[]

  @@map("users")
}

model Profile {
  id String @id @default(uuid()) @map("profile_id")
  userId String            @unique @map("user_id") // Relasi 1-to-1 wajib @unique
  fullName          String?        @map("full_name") @db.VarChar(100)
  whatsappNumber    String?        @map("whatsapp_number") @db.VarChar(20)
  maritalStatus     MaritalStatus? @map("marital_status")
  fotoProfileUrl    String?        @map("foto_profile_url") @db.Text
  fotoKtpUrl        String?        @map("foto_ktp_url") @db.VarChar(255)
  fotoBukuNikahUrl  String?        @map("foto_buku_nikah_url") @db.VarChar(255)
  isProfileComplete Boolean        @default(false) @map("is_profile_complete")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at")

  // Referensi ke model User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Room {
  id String @id @default(uuid()) @map("room_id")
  roomNumber   String     @map("room_number") @db.VarChar(10)
  floor        Int?
  roomType     RoomType   @default(studio) @map("room_type")
  priceDaily   Decimal?   @map("price_daily") @db.Decimal(12, 2)
  priceWeekly  Decimal?   @map("price_weekly") @db.Decimal(12, 2)
  priceMonthly Decimal    @map("price_monthly") @db.Decimal(12, 2)
  status       RoomStatus @default(available)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")
  length       Decimal
  width        Decimal
  area         Decimal?
  unit         String     @default("m")

  // Relasi
  roomFacilities RoomFacility[]
  bookings       Booking[]
  maintenances   Maintenance[]

  @@map("rooms")
}

model RoomFacility {
  roomId String @map("room_id")
  facilityId String @map("facility_id")

  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([roomId, facilityId])
  @@map("room_facilities")
}

// ---------------------------------------------------------
// 4. TRANSACTIONAL TABLES (Core Bisnis)
// ---------------------------------------------------------

model Booking {
  id String @id @default(uuid()) @map("booking_id")
  tenantId String           @map("tenant_id")
  roomId String           @map("room_id")
  rentType     RentType      @map("rent_type")
  duration     Int
  startDate    DateTime      @map("start_date") @db.Date
  endDate      DateTime      @map("end_date") @db.Date
  pricePerUnit Decimal       @map("price_per_unit") @db.Decimal(12, 2)
  totalPrice   Decimal       @map("total_price") @db.Decimal(12, 2)
  status       BookingStatus @default(pending_payment)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")

  // Relasi
  tenant   User      @relation("TenantBookings", fields: [tenantId], references: [id])
  room     Room      @relation(fields: [roomId], references: [id])
  invoices Invoice[]
  review   Review?

  @@map("bookings")
}

model Invoice {
  id String @id @default(uuid()) @map("invoice_id")
  bookingId String           @map("booking_id")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  penaltyAmount Decimal?      @default(0) @map("penalty_amount") @db.Decimal(12, 2)
  dueDate       DateTime      @map("due_date") @db.Timestamp()
  status        InvoiceStatus @default(unpaid)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")

  // Relasi
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("invoices")
}

model Transaction {
  id String @id @default(uuid()) @map("transaction_id")
  invoiceId String               @map("invoice_id")
  amount        Decimal           @db.Decimal(12, 2)
  paymentMethod String?           @map("payment_method") @db.VarChar(50)
  proofUrl      String?           @map("proof_url") @db.Text
  status        TransactionStatus @default(pending)
  rejectReason  String?           @map("reject_reason") @db.Text
  verifiedById String?              @map("verified_by")
  paidAt        DateTime?         @map("paid_at") @db.Timestamp()
  createdAt     DateTime          @default(now()) @map("created_at")

  // Relasi
  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  verifiedBy User?   @relation("VerifiedTransactions", fields: [verifiedById], references: [id])

  @@map("transactions")
}

// ---------------------------------------------------------
// 5. INTERACTION TABLES (Layanan & Feedback)
// ---------------------------------------------------------

model Maintenance {
  id String @id @default(uuid()) @map("maintenance_id")
  tenantId String?              @map("tenant_id")
  roomId String?              @map("room_id")
  category    ComplaintCategory
  description String            @db.Text
  images      String[]          @db.Text // Array URL
  status      ComplaintStatus   @default(open)
  adminNotes  String?           @map("admin_notes") @db.Text
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")

  // Relasi
  tenant User? @relation("TenantMaintenances", fields: [tenantId], references: [id])
  room   Room? @relation(fields: [roomId], references: [id])

  @@map("maintenances")
}

model Review {
  id String @id @default(uuid()) @map("review_id")
  bookingId String      @unique @map("booking_id")
  rating    Int?
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relasi
  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

// ---------------------------------------------------------
// 6. COMMUNICATION TABLES (Coming Soon Features)
// ---------------------------------------------------------

model Conversation {
  id String @id @default(uuid()) @map("conversation_id")
  tenantId String      @map("tenant_id")
  lastMessage String?  @map("last_message") @db.Text
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relasi
  tenant   User      @relation("TenantConversations", fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id String @id @default(uuid()) @map("message_id")
  conversationId String      @map("conversation_id")
  senderId String      @map("sender_id")
  messageText    String   @map("message_text") @db.Text
  isRead         Boolean? @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relasi
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id String @id @default(uuid()) @map("notification_id")
  userId String?             @map("user_id")
  title     String           @db.VarChar(255)
  message   String           @db.Text
  type      NotificationType @default(info)
  relatedId String?          @map("related_id") @db.VarChar(50)
  isRead    Boolean?         @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relasi
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
